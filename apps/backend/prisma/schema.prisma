datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model SanctuaryUser {
  id        Int      @id @default(autoincrement())
  name      String
  dob       String
  passcode  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Admin {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WebsiteContent {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String   @db.Text // Store large stringified JSON payloads
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
